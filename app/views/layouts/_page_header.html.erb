<div class="row">
	<div class="col-12 mt-3 mt-lg-4 mt-xl-5">
		<div class="page-header">
			<h2 itemprop="mainContentOfPage"><span><%=@controller_name %></span></h2>
			<% breadcrumbs.tap do |links| %>
				<% if links.any? %>
					<ol class="breadcrumb">
						<% links.each do |link| %>
						  <li class="breadcrumb-item<%= ' active' if link.current? %>">
							<%= link_to_unless(link.current?, link.text, link.url) %>
						  </li>
						<% end %>
					</ol>
				<% end %>
			  <% end %>
		</div>
	</div>
</div>
